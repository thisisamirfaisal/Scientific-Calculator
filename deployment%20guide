### Cell 3 — Start the app + expose with ngrok

```python
import subprocess, threading, time
from pyngrok import ngrok, conf

# 1. Get a free token at https://ngrok.com → Dashboard → Your Authtoken
NGROK_TOKEN = "PASTE_YOUR_NGROK_AUTHTOKEN_HERE"
conf.get_default().auth_token = NGROK_TOKEN

# 2. Start Streamlit in the background
def _run():
    subprocess.run([
        "streamlit", "run", "app.py",
        "--server.port", "8501",
        "--server.headless", "true",
        "--server.enableCORS", "false",
        "--server.enableXsrfProtection", "false",
    ])

threading.Thread(target=_run, daemon=True).start()
time.sleep(5)   # wait for boot

# 3. Open a public tunnel
url = ngrok.connect(8501)
print(f"\n🚀  Live at: {url}\n")
```

